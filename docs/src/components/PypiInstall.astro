---
/**
 * Install snippet that resolves the latest version from PyPI at build time.
 *
 * Props:
 *   manager: "pip" | "uv"
 */
interface Props {
  manager: "pip" | "uv";
}

const { manager } = Astro.props;

let resolvedVersion = "…";
try {
  const pins = await import("../data/pypi-install-pins.json");
  resolvedVersion = pins["astrocyte"] ?? "…";
} catch {
  try {
    const samplePins = await import("../data/pypi-install-pins.sample.json");
    resolvedVersion = samplePins["astrocyte"] ?? "…";
  } catch {
    // prebuild hasn't run yet — show placeholder
  }
}

const prefix = manager === "uv" ? "uv pip install" : "pip install";
const installCmd = `${prefix} astrocyte==${resolvedVersion} astrocyte-postgres==${resolvedVersion}`;
---

<pre
  class="astro-code"
  style="background-color: var(--astro-code-color-background); padding: 1rem; border-radius: 0.5rem; overflow-x: auto;"
  tabindex="0"
><code>{installCmd}</code></pre>
