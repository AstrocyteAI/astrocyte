<!--
  Astrocyte retain policy fragment for Azure API Management.

  Post-hook: Extracts the assistant message from an OpenAI-compatible
  /chat/completions response and retains it as a new memory via the
  Astrocyte gateway.

  Named values required:
    - astrocyte-gateway-url  (e.g. https://astrocyte.internal:8900)
    - astrocyte-api-key      (API key for gateway authentication)

  Usage:
    <include-fragment fragment-id="astrocyte-retain-extract" />
-->
<fragment>
  <choose>
    <when condition="@(context.Response.StatusCode == 200 && context.Response.Body != null)">
      <set-variable name="responseBody" value="@(context.Response.Body.As<string>(preserveContent: true))" />
      <set-variable name="assistantText" value="@{
        try {
          var body = JObject.Parse((string)context.Variables["responseBody"]);
          var choices = body["choices"] as JArray;
          if (choices != null && choices.Count > 0) {
            var message = choices[0]["message"];
            if (message != null && message["role"]?.ToString() == "assistant") {
              return message["content"]?.ToString() ?? "";
            }
          }
        } catch { }
        return "";
      }" />
      <!-- Resolve bank_id from original request header -->
      <set-variable name="retainBankId" value="@{
        var header = context.Request.Headers.GetValueOrDefault("X-Astrocyte-Bank", "");
        return string.IsNullOrEmpty(header) ? "default" : header;
      }" />
      <choose>
        <when condition="@(!string.IsNullOrEmpty((string)context.Variables["assistantText"]))">
          <!-- Fire-and-forget retain -->
          <send-request mode="new" timeout="5">
            <set-url>@($"{{{{astrocyte-gateway-url}}}}/v1/retain")</set-url>
            <set-method>POST</set-method>
            <set-header name="Content-Type" exists-action="override">
              <value>application/json</value>
            </set-header>
            <set-header name="X-Api-Key" exists-action="override">
              <value>{{astrocyte-api-key}}</value>
            </set-header>
            <set-body>@{
              return new JObject(
                new JProperty("content", (string)context.Variables["assistantText"]),
                new JProperty("bank_id", (string)context.Variables["retainBankId"]),
                new JProperty("tags", new JArray("llm_response", "azure-apim"))
              ).ToString();
            }</set-body>
          </send-request>
        </when>
      </choose>
    </when>
  </choose>
</fragment>
