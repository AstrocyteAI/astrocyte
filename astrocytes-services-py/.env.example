# Copy to `.env` and adjust (Docker Compose loads `.env` from this directory automatically).
# Do not commit `.env` — it is gitignored at the repo root.

# --- PostgreSQL (pgvector service) ---
POSTGRES_USER=astrocytes
POSTGRES_PASSWORD=astrocytes
POSTGRES_DB=astrocytes

# Host port published for Postgres (container listens on 5432).
POSTGRES_PUBLISH_PORT=5433

# --- astrocytes-rest HTTP ---
# Host port published for the REST API (container listens on ASTROCYTES_PORT).
ASTROCYTES_HTTP_PUBLISH_PORT=8080

ASTROCYTES_HOST=0.0.0.0
ASTROCYTES_PORT=8080
ASTROCYTES_VECTOR_STORE=pgvector

# --- Database URLs (do not confuse these) ---
#
# For Docker Compose, the API container always gets a DSN pointing at the `postgres` service
# (built from POSTGRES_* above). Override only if you need extra libpq params:
#   ASTROCYTES_REST_DATABASE_URL=postgresql://astrocytes:astrocytes@postgres:5432/astrocytes?sslmode=disable
#
# Do NOT set generic DATABASE_URL=...@127.0.0.1:5433 here for “running migrations on the host” —
# Compose would inject that into astrocytes-rest and /health would hang (503). Use instead:
#
# Optional: full DSN for host-side `migrate.sh` / `scripts/runbook-up.sh` (127.0.0.1 + POSTGRES_PUBLISH_PORT).
# MIGRATE_DATABASE_URL=postgresql://astrocytes:encodedpassword@127.0.0.1:5433/astrocytes
