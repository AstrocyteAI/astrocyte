# Copy to `.env` and adjust (Docker Compose loads `.env` from this directory automatically).
# Do not commit `.env` — it is gitignored at the repo root.
#
# All Astrocyte process env vars use the prefix ASTROCYTE_* (singular). The legacy ASTROCYTES_* prefix is removed.

# --- PostgreSQL (pgvector) ---
# The image is PostgreSQL 16 + pgvector (it also bundles Apache AGE, but
# Astrocyte no longer uses AGE — graph ops are flat Postgres tables since M9,
# ADR-008).
POSTGRES_USER=astrocyte
POSTGRES_PASSWORD=astrocyte
POSTGRES_DB=astrocyte
# Built locally by docker compose by default; set to a published image if desired.
# Must match the compose default tag (docker-compose.yml builds this name).
ASTROCYTE_POSTGRES_IMAGE=astrocyte/astrocyte-postgres:local

# Host port published for Postgres (container listens on 5432).
POSTGRES_PUBLISH_PORT=5433

# --- astrocyte-gateway-py HTTP ---
# Host port published for the REST API (container listens on ASTROCYTE_PORT).
ASTROCYTE_HTTP_PUBLISH_PORT=8080

ASTROCYTE_HOST=0.0.0.0
ASTROCYTE_PORT=8080
# Entry-point name registered by adapters-storage-py/astrocyte-postgres.
# `postgres` is canonical; `pgvector` is kept as a backwards-compat alias.
ASTROCYTE_VECTOR_STORE=postgres
# graph_store is no longer set — Apache AGE was removed in M9 (ADR-008).
# Tier-2 graph operations live inside the Postgres adapter as flat tables;
# setting graph_store: age now raises ConfigError on startup.
#
# `postgres` matches the compose default and the Postgres-backed stack this
# file provisions. `in_memory` is test/demo-only (loses the wiki on restart).
ASTROCYTE_WIKI_STORE=postgres

# --- REST auth (see astrocyte_gateway/auth.py) ---
# dev | api_key | jwt_hs256 | jwt_oidc (default: dev — trusts X-Astrocyte-Principal)
# ASTROCYTE_AUTH_MODE=dev
# ASTROCYTE_API_KEY=
# ASTROCYTE_JWT_SECRET=
# ASTROCYTE_JWT_AUDIENCE=
# ASTROCYTE_JWT_ISSUER=        # bind HS256 tokens to a trusted issuer (requires + matches `iss`)

# --- Edge hardening / DoS (see astrocyte_gateway/app.py, auth.py) ---
# The gateway refuses to start in dev auth mode on a public (non-loopback) bind
# unless you opt in. Admin endpoints fail closed without a token on a public bind.
# ASTROCYTE_ALLOW_DEV_AUTH=1       # allow unauthenticated dev mode on 0.0.0.0 (behind a trusted proxy only)
# ASTROCYTE_ADMIN_TOKEN=           # required to enable admin/governance endpoints on a public bind
# ASTROCYTE_MAX_REQUEST_BODY_BYTES=  # body-size cap (default 10 MiB; 0 disables)
# ASTROCYTE_RATE_LIMIT_PER_SECOND=   # per-client req/s (default: on at 100 for public binds, off on loopback; 0 disables)
# ASTROCYTE_MAX_RESULT_LIMIT=        # ceiling for max_results / limit / max_memories (default 1000)
# ASTROCYTE_GRAPH_MAX_DEPTH=         # ceiling for graph neighbor traversal depth (default 6)

# --- Database URLs (do not confuse these) ---
#
# For Docker Compose, the API container always gets a DSN pointing at the `postgres` service
# (built from POSTGRES_* above). Override only if you need extra libpq params:
#   ASTROCYTE_GATEWAY_DATABASE_URL=postgresql://astrocyte:astrocyte@postgres:5432/astrocyte?sslmode=disable
#   (legacy alias: ASTROCYTE_REST_DATABASE_URL)
#
# Do NOT set generic DATABASE_URL=...@127.0.0.1:5433 here for “running migrations on the host” —
# Compose would inject that into astrocyte-gateway-py and /health would hang (503). Use instead:
#
# Optional: full DSN for host-side `migrate.sh` / `scripts/runbook-up.sh` (127.0.0.1 + POSTGRES_PUBLISH_PORT).
# MIGRATE_DATABASE_URL=postgresql://astrocyte:encodedpassword@127.0.0.1:5433/astrocyte
